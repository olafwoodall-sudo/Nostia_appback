## Copy this file to local.properties and fill in real values.
## local.properties is gitignored and must never be committed.

# Android SDK path (Android Studio sets this automatically)
sdk.dir=/Users/YOUR_USERNAME/AppData/Local/Android/Sdk

# Release signing keystore
KEYSTORE_FILE=../nostia-release.jks
KEYSTORE_PASSWORD=YOUR_KEYSTORE_PASSWORD
KEY_ALIAS=nostia
KEY_PASSWORD=YOUR_KEY_PASSWORD

# Google Maps API key (restricted to com.nostia.app + your SHA-1)
MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Stripe publishable key (from Stripe Dashboard > Developers > API keys)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_KEY
