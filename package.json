{
  "name": "nostia-backend",
  "version": "1.0.0",
  "description": "Nostia social adventure app backend - connecting travelers and adventurers",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit": "npm audit --omit=dev",
    "audit:fix": "npm audit fix --omit=dev",
    "backup": "node -e \"const fs=require('fs');const d=new Date().toISOString().slice(0,10);fs.copyFileSync('database/nostia.db','database/backups/nostia-'+d+'.db');console.log('Backup created: nostia-'+d+'.db')\"",
    "prestart": "npm audit --omit=dev --audit-level=high || true"
  },
  "keywords": [
    "travel",
    "social",
    "adventure",
    "trip-planning",
    "mongodb",
    "express"
  ],
  "author": "olaf woodall",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
